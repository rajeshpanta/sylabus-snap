{
  "expo": {
    "name": "Semora",
    "slug": "semora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "semora",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0b24"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rajeshpanta.syllabussnap",
      "appleTeamId": "7T9897GFKH",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "expo-calendar",
        {
          "calendarPermission": "Semora needs calendar access to sync your task due dates."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6B46C1"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Semora needs photo access to upload syllabus images.",
          "cameraPermission": "Semora needs camera access to scan syllabi."
        }
      ],
      "expo-document-picker",
      "react-native-iap"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "063fbdf9-33e3-49b4-8b0b-ba9d6f18490b"
      }
    },
    "owner": "smallpantas-organization"
  }
}
