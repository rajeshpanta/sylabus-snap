{
  "expo": {
    "name": "SyllabusSnap",
    "slug": "SyllabusSnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "syllabussnap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0b24"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.SyllabusSnap"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "expo-calendar",
        {
          "calendarPermission": "SyllabusSnap needs calendar access to sync your task due dates."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6B46C1"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SyllabusSnap needs photo access to upload syllabus images.",
          "cameraPermission": "SyllabusSnap needs camera access to scan syllabi."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
